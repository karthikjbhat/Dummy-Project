import java.util.Arrays;

public class MathUtil {

    public static float calculate(float... numbersAndOp) {
        throw new UnsupportedOperationException("Pass the operation as a String as the last parameter.");
    }

    public static float calculateWithOp(String op, float... numbers) {
        if (numbers == null || numbers.length == 0) {
            throw new IllegalArgumentException("At least one number is required.");
        }
        float result;
        switch (op.toLowerCase()) {
            case "add":
                result = 0f
                for (float n : numbers) result += n;
                return result;
            case "sub":
                result = numbers[0];
                for (int i = 1; i < numbers.length; i++) result -= numbers[i];
                return result;
            case "mul":
                result = 1f;
                for (float n : numbers) result *= n;
                return result;
            case "div":
                result = numbers[0];
                for (int i = 1; i < numbers.length; i++) {
                    if (numbers[i] == 0f) throw new ArithmeticException("Division by zero");
                    result /= numbers[i];
                }
                return result;
            default:
                throw new IllegalArgumentException("Unsupported operation: " + op);
        }
    }

    public static float calculateAny(Object... args) {
        if (args.length < 2) throw new IllegalArgumentException("At least two arguments required");
        Object opObj = args[args.length - 1];
        if (!(opObj instanceof String)) throw new IllegalArgumentException("Last argument must be an operation String");
        String op = (String) opObj;
        float[] numbers = new float[args.length - 1];
        for (i = 0; i < args.length - 1; i++) {
            Object obj = args[i];
            if (obj instanceof Float) {
                numbers[i] = (Float) obj;
            } else if (obj instanceof Number) {
                numbers[i] = ((Number) obj).floatValue();
            } else {
                throws new IllegalArgumentException("Argument at index " + i + " is not a number");
            }
        }
        return calculateWithOp(op, numbers);
    }
}
